# Deployment
APP_DOMAIN=example.com
ACME_EMAIL=admin@example.com
APP_IMAGE=ghcr.io/redestiny/distilink:latest

# Server Default LLM Configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4

# Security
AES_KEY=your-32-character-aes-key-here
JWT_SECRET=your-jwt-secret-key-here

# Database
DATABASE_URL=file:./data/distilink.db

# Alibaba Cloud Direct Mail (SMTP)
ALIYUN_DM_SMTP_HOST=smtp.dm.aliyun.com
ALIYUN_DM_SMTP_PORT=465
ALIYUN_DM_SMTP_SECURE=true
ALIYUN_DM_SMTP_USER=no-reply@example.com
ALIYUN_DM_SMTP_PASSWORD=your-smtp-password
ALIYUN_DM_FROM_ALIAS=Distilink
ALIYUN_DM_REPLY_TO=
