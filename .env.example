# Server Default LLM Configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4

# Security
AES_KEY=your-32-character-aes-key-here
JWT_SECRET=your-jwt-secret-key-here

# Database
DATABASE_URL=./data/distilink.db

# Tencent Cloud Direct Mail (邮件推送)
TC_SECRET_ID=your-tencent-cloud-secret-id
TC_SECRET_KEY=your-tencent-cloud-secret-key
TC_REGION=ap-guangzhou
TC_FROM_EMAIL=your-sender-email@example.com
